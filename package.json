{
  "name": "racecontrol-driver",
  "version": "2.0.1",
  "description": "RaceLeague Driver Panel",
  "main": "src/main.js",
  "author": "AleEjx",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --publish never"
  },
  "build": {
    "appId": "com.raceleague.driver",
    "productName": "RaceLeague Driver",
    "publish": {
      "provider": "github",
      "owner": "AleEjx",
      "repo": "racecontrol-app"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ]
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "electron-updater": "^6.1.7"
  }
}
